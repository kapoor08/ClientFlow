  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "auth:generate": "npx @better-auth/cli@latest generate --config ./lib/auth.ts --output ./db/auth-schema.ts --yes",
