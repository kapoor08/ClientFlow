{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "..",
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["./main.ts", "./preload.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
